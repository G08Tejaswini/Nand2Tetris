
CHIP DMux {
    IN in, sel;
    OUT a, b;

    //Dmux takes 1 input and 1 selector and gives 2 outputs

    PARTS:
    Not(in= sel, out=nots );      //Inverting sel to control our output  
    And(a= in, b=sel , out=b);    // sel=1: input goes to b 
    And(a= in, b=nots , out=a);   // sel=1: input goes to     
}
